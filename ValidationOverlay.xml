<GuiXml>
    <Controls>
        <!-- Row template: one per roster slot -->
        <Control name="ESOtk_OverlayRowTemplate" virtual="true">
            <Dimensions x="340" y="24" />
            <Controls>
                <!-- Status icon (pass/fail/warning) -->
                <Label name="$(parent)Status" font="ZoFontGameSmall"
                       text="?" color="FFFF00"
                       horizontalAlignment="CENTER" verticalAlignment="CENTER">
                    <Dimensions x="20" y="24" />
                    <Anchor point="LEFT" relativeTo="$(parent)" relativePoint="LEFT" offsetX="4" />
                </Label>
                <!-- Slot label (tank1, healer2, dps3, etc.) -->
                <Label name="$(parent)Slot" font="ZoFontGameSmall"
                       text="slot" color="00FFFF"
                       horizontalAlignment="LEFT" verticalAlignment="CENTER">
                    <Dimensions x="55" y="24" />
                    <Anchor point="LEFT" relativeTo="$(parent)Status" relativePoint="RIGHT" offsetX="2" />
                </Label>
                <!-- Player name -->
                <Label name="$(parent)Player" font="ZoFontGameSmall"
                       text="" color="FFFFFF"
                       horizontalAlignment="LEFT" verticalAlignment="CENTER">
                    <Dimensions x="140" y="24" />
                    <Anchor point="LEFT" relativeTo="$(parent)Slot" relativePoint="RIGHT" offsetX="2" />
                </Label>
                <!-- Detail (role mismatch, offline, etc.) -->
                <Label name="$(parent)Detail" font="ZoFontGameSmall"
                       text="" color="AAAAAA"
                       horizontalAlignment="LEFT" verticalAlignment="CENTER">
                    <Dimensions x="115" y="24" />
                    <Anchor point="LEFT" relativeTo="$(parent)Player" relativePoint="RIGHT" offsetX="2" />
                </Label>
            </Controls>
        </Control>

        <!-- Main overlay window -->
        <TopLevelControl name="ESOtk_ValidationOverlay" movable="true" mouseEnabled="true"
                         clampedToScreen="true" hidden="true" layer="OVERLAY" level="100">
            <Dimensions x="360" y="120" />
            <Anchor point="TOPRIGHT" relativeTo="GuiRoot" relativePoint="TOPRIGHT"
                    offsetX="-20" offsetY="80" />

            <!-- Background -->
            <Controls>
                <Backdrop name="$(parent)BG" inherits="ZO_DefaultBackdrop"
                          centerColor="000000" edgeColor="333333">
                    <AnchorFill />
                    <Alpha alpha="0.82" />
                </Backdrop>

                <!-- Title bar -->
                <Control name="$(parent)Header">
                    <Dimensions x="360" y="28" />
                    <Anchor point="TOPLEFT" relativeTo="$(parent)" relativePoint="TOPLEFT" />
                    <Controls>
                        <!-- Title text -->
                        <Label name="$(parent)Title" font="ZoFontGameBold"
                               text="ESOtk Roster Validation" color="00FFFF"
                               horizontalAlignment="LEFT" verticalAlignment="CENTER">
                            <Dimensions x="280" y="28" />
                            <Anchor point="LEFT" relativeTo="$(parent)" relativePoint="LEFT"
                                    offsetX="8" />
                        </Label>
                        <!-- Close button -->
                        <Button name="$(parent)Close" font="ZoFontGameSmall"
                                text="X" normalColor="FF4444" mouseOverColor="FF8888">
                            <Dimensions x="24" y="24" />
                            <Anchor point="RIGHT" relativeTo="$(parent)" relativePoint="RIGHT"
                                    offsetX="-4" />
                            <OnClicked>ESOtk.ValidationOverlay.Toggle()</OnClicked>
                        </Button>
                    </Controls>
                </Control>

                <!-- Summary line -->
                <Label name="$(parent)Summary" font="ZoFontGameSmall"
                       text="" color="AAAAAA"
                       horizontalAlignment="LEFT" verticalAlignment="CENTER">
                    <Dimensions x="340" y="20" />
                    <Anchor point="TOPLEFT" relativeTo="$(parent)Header" relativePoint="BOTTOMLEFT"
                            offsetX="8" />
                </Label>

                <!-- Divider -->
                <Texture name="$(parent)Divider" color="444444">
                    <Dimensions x="340" y="1" />
                    <Anchor point="TOPLEFT" relativeTo="$(parent)Summary" relativePoint="BOTTOMLEFT"
                            offsetX="-4" offsetY="2" />
                </Texture>

                <!-- Row container (rows are created dynamically) -->
                <Control name="$(parent)Rows">
                    <Dimensions x="350" y="1" />
                    <Anchor point="TOPLEFT" relativeTo="$(parent)Divider" relativePoint="BOTTOMLEFT"
                            offsetX="4" offsetY="4" />
                </Control>
            </Controls>
        </TopLevelControl>
    </Controls>
</GuiXml>
